DATABASE_URL="postgresql://postgres:password@localhost:5435/openticket_db?schema=public"
REDIS_URL="redis://localhost:6380"
JWT_SECRET="superSecretKey123"
PORT=3000

# URLs públicas — cambiar al dominio real en producción
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SITE_URL=http://localhost:4200
NEXT_PUBLIC_HOST_URL=http://localhost:4201
NEXT_PUBLIC_ADMIN_URL=http://localhost:4202

# ─── Email (Nodemailer SMTP) ──────────────────────────────────────────────────
# Solo configura estas 5 variables para activar el envío de correos.
# Compatible con cualquier proveedor SMTP: Gmail, Resend, Mailgun, SendGrid, etc.
#
# Ejemplo Gmail (desarrollo):
#   MAIL_HOST=smtp.gmail.com  MAIL_PORT=587  MAIL_SECURE=false
#   MAIL_USER=tucuenta@gmail.com
#   MAIL_PASS=xxxx xxxx xxxx xxxx   (contraseña de aplicación, no la de la cuenta)
#
# Ejemplo Resend (recomendado para producción):
#   MAIL_HOST=smtp.resend.com  MAIL_PORT=465  MAIL_SECURE=true
#   MAIL_USER=resend  MAIL_PASS=re_xxxxxxxxxxxx
#
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=AfroEventos <no-reply@afroeventos.com>

# ─── Almacenamiento de imágenes ───────────────────────────────────────────────
# STORAGE_PROVIDER=local     → guarda en ./uploads/ del servidor (VPS) — por defecto
# STORAGE_PROVIDER=cloudinary → sube a Cloudinary (requiere las 3 vars siguientes)
#
# Para activar Cloudinary:
#   1. Crea cuenta en https://cloudinary.com (plan gratuito)
#   2. Copia las credenciales desde el Dashboard → API Keys
#   3. Cambia STORAGE_PROVIDER=cloudinary y rellena las 3 vars
#   4. Reinicia la API
#
STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Límite de tamaño de imágenes ────────────────────────────────────────────
# Tamaño máximo permitido para subir imágenes (en MB).
# Afecta backend y los 3 frontends. Reiniciar todos los servicios al cambiar.
NEXT_PUBLIC_MAX_UPLOAD_MB=2.5

# Tipos de imagen permitidos para subir (separados por coma, sin espacios)
# SVG excluido por riesgo de seguridad (XSS embebido) — el logo SVG del proyecto es estático
NEXT_PUBLIC_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ─── Optimización de imágenes (Sharp) ────────────────────────────────────────
# Calidad de compresión WebP (1-100). 80 = excelente calidad visual, ~60% menos peso.
# No se redimensiona — el organizador sube cada imagen con la proporción correcta.
UPLOAD_IMAGE_QUALITY=80
