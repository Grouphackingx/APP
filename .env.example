# ─────────────────────────────────────────────────────────────
# AfroEventos — Plantilla de variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas el `.env` real al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Base de datos (PostgreSQL — puerto local no estándar 5435)
DATABASE_URL=postgresql://postgres:password@localhost:5435/openticket_db?schema=public

# Cache / locks (Redis — puerto local no estándar 6380)
REDIS_URL=redis://localhost:6380

# Seguridad — genera uno aleatorio de 64 chars en producción
JWT_SECRET=changeme-genera-un-secreto-aleatorio-largo

# API
PORT=3000

# URLs públicas (Next.js — en Coolify van como Build Variables, no Env Vars)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SITE_URL=http://localhost:4200
NEXT_PUBLIC_HOST_URL=http://localhost:4201
NEXT_PUBLIC_ADMIN_URL=http://localhost:4202

# Email (Resend SMTP — dejar MAIL_HOST vacío para modo silencioso local)
# Puerto 465 está bloqueado en el hosting: usar siempre 587 + MAIL_SECURE=false (STARTTLS)
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=resend
MAIL_PASS=tu_resend_api_key
MAIL_FROM=AfroEventos <no-reply@afroeventos.com>

# Almacenamiento de imágenes (local = VPS | cloudinary = CDN)
STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Límites y formatos de imágenes (afectan backend + 3 frontends)
NEXT_PUBLIC_MAX_UPLOAD_MB=2.5
NEXT_PUBLIC_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
UPLOAD_IMAGE_QUALITY=80
