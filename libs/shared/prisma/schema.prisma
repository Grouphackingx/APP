datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  HOST
  ADMIN
  STAFF
}

enum EventStatus {
  DRAFT
  PUBLISHED // Acts as ACTIVO
  INACTIVE  // INACTIVO
}

enum TicketStatus {
  VALID
  USED
  REFUNDED
}


enum HostStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  
  eventsOwned Event[]  @relation("EventOwner")
  orders      Order[]
  
  organizerProfile OrganizerProfile?
}

model Event {
  id          String      @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String
  province    String?
  city        String?
  imageUrl    String?
  seatingMapImageUrl String?
  hasSeatingChart Boolean @default(true)
  mapUrl      String?
  videoUrl    String?
  galleryUrls String[]
  status      EventStatus @default(DRAFT)
  
  organizerId String
  organizer   User        @relation("EventOwner", fields: [organizerId], references: [id])
  
  zones       Zone[]
  createdAt   DateTime    @default(now())
}

model Zone {
  id        String  @id @default(uuid())
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id])
  name      String
  description String?
  price     Decimal @db.Decimal(10, 2)
  capacity  Int
  
  isReservedSeating Boolean @default(false)
  seats             Seat[]
}

model Seat {
  id        String  @id @default(uuid())
  zoneId    String
  zone      Zone    @relation(fields: [zoneId], references: [id])
  row       String?
  number    String?
  isSold    Boolean @default(false)
}

model Order {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  totalAmount   Decimal
  status        String
  paymentRef    String?
  tickets       Ticket[]
  createdAt     DateTime @default(now())
}

model Ticket {
  id           String       @id @default(uuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id])
  qrCodeToken  String       @unique
  status       TicketStatus @default(VALID)
  scannedAt    DateTime?
}

model OrganizerProfile {
  id                      String     @id @default(uuid())
  userId                  String     @unique
  user                    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName               String
  lastName                String
  identificationNumber    String
  phone                   String
  
  organizationName        String
  organizationDescription String?
  organizationLogo        String?
  
  address                 String?
  province                String?
  city                    String?
  
  plan                    String     @default("FREE")
  status                  HostStatus @default(PENDING)
  
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
}

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique
  maxEvents   Int
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
